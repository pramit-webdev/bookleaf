					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/books",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"books"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Book Detail",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/books/BK001",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"books",
								"BK001"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Tickets",
			"item": [
				{
					"name": "Submit Ticket (AI Classification)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"book_id\": \"BK001\",\n    \"subject\": \"ISBN missing for my book\",\n    \"description\": \"I see my book 'Code & Karma' is live on Amazon, but the ISBN is blank in this portal. Can you please update it?\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tickets",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets"
							]
						}
					},
					"response": []
				},
				{
					"name": "List My Tickets",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/tickets",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets"
							]
						}
					},
					"response": []
				},
				{
					"name": "Admin: Update Ticket (Status/Priority)",
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"In Progress\",\n    \"priority\": \"High\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tickets/{{ticket_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets",
								"{{ticket_id}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Admin: Get AI Draft Response",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/tickets/{{ticket_id}}/draft",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets",
								"{{ticket_id}}",
								"draft"
							]
						}
					},
					"response": []
				},
				{
					"name": "Add Response to Ticket",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Thank you for bringing this to our attention. Our team is looking into the payment delay and will get back to you within 48 hours.\",\n    \"is_internal\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tickets/{{ticket_id}}/responses",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets",
								"{{ticket_id}}",
								"responses"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
